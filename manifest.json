{
  "manifest_version": 3,
  "name": "FactRadar",
  "version": "1.9",
  "description": "Automatically check the reliability of web pages, news and emails with AI.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://truthcheck-ai-production.up.railway.app/*",
    "*://mail.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["translations.js", "content.js"]
    }
  ]
}