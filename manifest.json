{
  "manifest_version": 3,
  "name": "TruthCheck AI",
  "version": "1.6",
  "description": "Controleer automatisch de betrouwbaarheid van webpagina's, nieuws en e-mails met AI.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://truthcheck-ai-production.up.railway.app/*",
    "*://mail.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}