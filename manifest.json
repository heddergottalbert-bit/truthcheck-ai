{
  "manifest_version": 3,
  "name": "TruthCheck AI",
  "version": "1.3",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "*://api.tavily.com/*",
    "*://api.openai.com/*",
    "*://mail.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}